generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
 SALES
 ACCOUNTMANAGER
 OPERATIONS
 FINANCE
 VIEWER
 INTERNAL
}

enum PracticeStatus {
  LEAD
  ACTIVE
  INACTIVE
  CLOSED
}

enum PracticeSource {
  DIRECT
  REFERRAL
  CHANNEL_PARTNER
  OUTBOUND
  INBOUND
}

enum PersonRole {
  OWNER
  ADMIN
  FINANCE
  OPERATIONS
  CLINICAL
  PROCUREMENT
  OTHER
}

enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
  DECISION_MAKER
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum AgreementType {
  MSA
  SOW
  RENEWAL
  ADDENDUM
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum VendorType {
  BILLING
  CODING
  RCM
  COMPLIANCE
  TECHNOLOGY
  OTHER
}

enum AuditType {
  COMPLIANCE
  CODING
  DOCUMENTATION
  REVENUE_CYCLE
  OPERATIONAL
}

enum OnboardingType {
  SINGLE_PRACTICE
  MULTIPLE_PRACTICES
  SINGLE_PRACTICE_NOW
}

enum OnboardingStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ContactRole {
  EXECUTIVE_OWNER
  OFFICE_MANAGER
  PRACTICE_MANAGER
  BILLING
  CREDENTIALING
  CLINICAL_STAFF
  IT_TECHNICAL
  CONSULTANT
  OTHER
}

enum OrganizationType {
  INDEPENDENT_PRACTICE
  MEDICAL_GROUP
  MULTI_SPECIALTY_GROUP
  MSO
  IPA
  DSO
  FQHC
  HOSPITAL_AFFILIATED_GROUP
  PHARMACY_ORGANIZATION
  OTHER
}

enum OwnershipType {
  PHYSICIAN_OWNED
  CORPORATE_OWNED
  PRIVATE_EQUITY_BACKED
  HOSPITAL_AFFILIATED
  FAMILY_OWNED
  PARTNERSHIP
  OTHER
}

enum DocumentTypes {
  W9
  SIGNED_AGREEMENT
  BAA
  COI
  PROVIDER_ROSTER
  CAQH
  ENROLLMENT_LETTER
  BRANDING_ASSET
  BILLING_REPORT
  OTHER
}

enum DocumentStatus {
  NOT_REQUESTED
  REQUESTED
  RECEIVED
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum ServiceType {
  CREDENTIALING
  BILLING_RCM
  APCM
  CCM
  RPM
  PCM
  RTM
  BHI
  TCM
  LAB_RELATIONSHIP_SUPPORT
  PHARMACY_PROGRAM_SUPPORT
  PATIENT_ACQUISITION
  BRAND_GROWTH
  AI_VISIBILITY
  OTHER
}

enum CredentialingIssues {
  INCORRECT_SPECIALTY_ENROLLMENT
  MISSING_PAYER_ENROLLMENT
  EXPIRED_ENROLLMENT
  RECREDENTIALING_LETTER
  BRANDING_ASSET
  BILLING_REPORT
  OTHER
