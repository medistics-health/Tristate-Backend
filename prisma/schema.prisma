generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
 SALES
 ACCOUNTMANAGER
 OPERATIONS
 FINANCE
 VIEWER
}

enum PracticeStatus {
  LEAD
  ACTIVE
  INACTIVE
  CLOSED
}

enum PracticeSource {
  DIRECT
  REFERRAL
  CHANNEL_PARTNER
  OUTBOUND
  INBOUND
}

enum PersonRole {
  OWNER
  ADMIN
  FINANCE
  OPERATIONS
  CLINICAL
  PROCUREMENT
  OTHER
}

enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
  DECISION_MAKER
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum AgreementType {
  MSA
  SOW
  RENEWAL
  ADDENDUM
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum VendorType {
  BILLING
  CODING
  RCM
  COMPLIANCE
  TECHNOLOGY
  OTHER
}

enum AuditType {
  COMPLIANCE
  CODING
  DOCUMENTATION
  REVENUE_CYCLE
  OPERATIONAL
}

enum ChannelPartnerType {
  RESELLER
  REFERRAL
  IMPLEMENTATION
  STRATEGIC
}

enum CompanyStatus {
  LEAD
  CUSTOMER
  PARTNER
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  userName  String    @unique
  firstName String
  lastName  String
  email     String    @unique
  password  String
  role      UserRoles
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("User")
}

model Company {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  domain    String?
  industry  String?
  size      Int?
  revenue   Decimal?      @db.Decimal(15, 2)
  phone     String?
  email     String?
  website   String?
  street    String?
  city      String?
  state     String?
  country   String?
  zip       String?
  status    CompanyStatus @default(LEAD)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  practiceGroups PracticeGroup[]
  practices      Practice[]
  taxIds         TaxId[]
  persons       CompanyPerson[]

  @@map("companies")
}

model PracticeGroup {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  companyId String          @map("company_id") @db.Uuid
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  practices Practice[]
  groupNpis GroupNpi[]

  // FHIR-style recursive nesting (Groups within Groups)
  parentId  String?         @map("parent_id") @db.Uuid
  parent    PracticeGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  PracticeGroup[] @relation("GroupHierarchy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([parentId])
  @@map("practice_groups")
}

model Practice {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String?         @map("company_id") @db.Uuid
  practiceGroupId String?         @map("practice_group_id") @db.Uuid
  taxIdId         String?         @map("tax_id_id") @db.Uuid
  name            String
  npi             String?
  status          PracticeStatus
region          String
  source          PracticeSource
  bucket          String[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  practiceGroup   PracticeGroup?  @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  taxId           TaxId?          @relation(fields: [taxIdId], references: [id], onDelete: SetNull)
  groupNpis       GroupNpi[]      @relation("PracticeGroupNpis")
  persons         PracticePerson[]
  deals       Deal[]
  agreements  Agreement[]
  invoices    Invoice[]
  audits      Audit[]
  assessments Assessment[]

  @@index([companyId])
  @@index([practiceGroupId])
  @@index([taxIdId])
  @@map("practices")
}

model TaxId {
  id              String       @id @default(uuid()) @db.Uuid
  taxIdNumber     String       @unique @map("tax_id_number")
  legalEntityName String       @map("legal_entity_name")
  status          EntityStatus @default(ACTIVE)
  notes           String?
  companyId       String       @map("company_id") @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupNpis       GroupNpi[]
  practices       Practice[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("tax_ids")
}

model PracticePerson {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String @map("practice_id") @db.Uuid
  personId   String  @map("person_id") @db.Uuid
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  person     Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([personId])
  @@unique([practiceId, personId])
  @@map("practice_persons")
}

model CompanyPerson {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([personId])
  @@unique([companyId, personId])
  @@map("company_persons")
}

model GroupNpi {
  id              String         @id @default(uuid()) @db.Uuid
  groupNpiNumber  String         @unique @map("group_npi_number")
  groupName       String         @map("group_name")
  status          EntityStatus   @default(ACTIVE)
  notes           String?
  taxId           String?        @map("tax_id") @db.Uuid
  tax             TaxId?        @relation(fields: [taxId], references: [id], onDelete: Cascade)
  practiceGroupId String?        @map("practice_group_id") @db.Uuid
  practiceGroup   PracticeGroup? @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  practices       Practice[]     @relation("PracticeGroupNpis")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([taxId])
  @@index([practiceGroupId])
  @@map("group_npis")
}

model Person {
  id          String          @id @default(uuid()) @db.Uuid
  firstName   String          @map("first_name")
  lastName    String          @map("last_name")
  role        PersonRole
  designation String?
  influence   InfluenceLevel
  email       String?
  phone       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  practices   PracticePerson[]
  companies   CompanyPerson[]

  @@map("contacts")
}

model Deal {
  id                String      @id @default(uuid()) @db.Uuid
  practiceId        String      @map("practice_id") @db.Uuid
  stage             DealStage
  value             Decimal     @db.Decimal(12, 2)
  probability       Int
  expectedCloseDate DateTime?   @map("expected_close_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  practice          Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreements        Agreement[]
  audits            Audit[]

  @@index([practiceId])
  @@map("deals")
}

model Agreement {
  id                    String           @id @default(uuid()) @db.Uuid
  practiceId            String           @map("practice_id") @db.Uuid
  dealId                String?          @map("deal_id") @db.Uuid
  type                  AgreementType
  status                AgreementStatus
  effectiveDate         DateTime?        @map("effective_date")
  renewalDate           DateTime?        @map("renewal_date")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @default(now()) @updatedAt @map("updated_at")
  practice              Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal                  Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoices              Invoice[]
  channelPartners       ChannelPartner[]
  docusealSubmissions   DocusealSubmission[]

  @@index([practiceId])
  @@index([dealId])
  @@map("agreements")
}

model DocusealSubmission {
  id            String    @id @default(uuid()) @db.Uuid
  agreementId   String    @map("agreement_id") @db.Uuid
  externalId    Int       @unique @map("external_id")
  status        String
  url           String?
  templateId    Int?      @map("template_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  agreement     Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@map("docuseal_submissions")
}

model Service {
  id         String            @id @default(uuid()) @db.Uuid
  name       String
  clientRate Decimal           @map("client_rate") @db.Decimal(12, 2)
  vendorRate Decimal           @map("vendor_rate") @db.Decimal(12, 2)
  margin     Decimal           @db.Decimal(5, 2)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at")
  lineItems  InvoiceLineItem[]

  @@map("services")
}

model Invoice {
  id            String            @id @default(uuid()) @db.Uuid
  practiceId    String            @map("practice_id") @db.Uuid
  agreementId   String?           @map("agreement_id") @db.Uuid
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus
  dueDate       DateTime?         @map("due_date")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")
  practice      Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreement     Agreement?        @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  purchaseOrders PurchaseOrder[]

  @@index([practiceId])
  @@index([agreementId])
  @@map("invoices")
}

model InvoiceLineItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  serviceId  String   @map("service_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([serviceId])
  @@map("invoice_line_items")
}

model PurchaseOrder {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  totalCost Decimal  @map("total_cost") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([invoiceId])
  @@map("purchase_orders")
}

model Vendor {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  type           VendorType
  renewalDate    DateTime?       @map("renewal_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model Audit {
  id              String    @id @default(uuid()) @db.Uuid
  practiceId      String    @map("practice_id") @db.Uuid
  dealId          String?   @map("deal_id") @db.Uuid
  type            AuditType
  score           Decimal?  @db.Decimal(5, 2)
  findings        Json
  recommendations Json
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([dealId])
  @@map("audits")
}

model Assessment {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  responses  Json
  score      Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@map("assessments")
}

model ChannelPartner {
  id          String             @id @default(uuid()) @db.Uuid
  name        String
  type        ChannelPartnerType
  agreementId String?            @map("agreement_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  agreement   Agreement?         @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  @@index([agreementId])
  @@map("channel_partners")
}
