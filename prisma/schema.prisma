generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
 SALES
 ACCOUNTMANAGER
 OPERATIONS
 FINANCE
 VIEWER
}

enum PracticeStatus {
  LEAD
  ACTIVE
  INACTIVE
  CLOSED
}

enum PracticeSource {
  DIRECT
  REFERRAL
  CHANNEL_PARTNER
  OUTBOUND
  INBOUND
}

enum PersonRole {
  OWNER
  ADMIN
  FINANCE
  OPERATIONS
  CLINICAL
  PROCUREMENT
  OTHER
}

enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
  DECISION_MAKER
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum AgreementType {
  MSA
  SOW
  RENEWAL
  ADDENDUM
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum VendorType {
  BILLING
  CODING
  RCM
  COMPLIANCE
  TECHNOLOGY
  OTHER
}

enum AuditType {
  COMPLIANCE
  CODING
  DOCUMENTATION
  REVENUE_CYCLE
  OPERATIONAL
}

enum OnboardingType {
  SINGLE_PRACTICE
  MULTIPLE_PRACTICES
  SINGLE_PRACTICE_NOW
}

enum OnboardingStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ContactRole {
  EXECUTIVE_OWNER
  OFFICE_MANAGER
  PRACTICE_MANAGER
  BILLING
  CREDENTIALING
  CLINICAL_STAFF
  IT_TECHNICAL
  CONSULTANT
  OTHER
}

enum OrganizationType {
  INDEPENDENT_PRACTICE
  MEDICAL_GROUP
  MULTI_SPECIALTY_GROUP
  MSO
  IPA
  DSO
  FQHC
  HOSPITAL_AFFILIATED_GROUP
  PHARMACY_ORGANIZATION
  OTHER
}

enum OwnershipType {
  PHYSICIAN_OWNED
  CORPORATE_OWNED
  PRIVATE_EQUITY_BACKED
  HOSPITAL_AFFILIATED
  FAMILY_OWNED
  PARTNERSHIP
  OTHER
}

enum ServiceType {
  CREDENTIALING
  BILLING_RCM
  APCM
  CCM
  RPM
  PCM
  RTM
  BHI
  TCM
  LAB_RELATIONSHIP_SUPPORT
  PHARMACY_PROGRAM_SUPPORT
  PATIENT_ACQUISITION
  BRAND_GROWTH
  AI_VISIBILITY
  OTHER
}

enum BillingModel {
  IN_HOUSE
  OUTSOURCED
  HYBRID
}

enum ChannelPartnerType {
  RESELLER
  REFERRAL
  IMPLEMENTATION
  STRATEGIC
}

enum CompanyStatus {
  LEAD
  CUSTOMER
  PARTNER
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  userName  String    @unique
  firstName String
  lastName  String
  email     String    @unique
  password  String
  role      UserRoles
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("User")
}

model Company {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  domain    String?
  industry  String?
  size      Int?
  revenue   Decimal?      @db.Decimal(15, 2)
  phone     String?
  email     String?
  website   String?
  street    String?
  city      String?
  state     String?
  country   String?
  zip       String?
  status    CompanyStatus @default(LEAD)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  practiceGroups PracticeGroup[]
  practices      Practice[]
  taxIds         TaxId[]
  persons       CompanyPerson[]

  @@map("companies")
}

model PracticeGroup {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  companyId String          @map("company_id") @db.Uuid
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  practices Practice[]
  groupNpis GroupNpi[]

  // FHIR-style recursive nesting (Groups within Groups)
  parentId  String?         @map("parent_id") @db.Uuid
  parent    PracticeGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  PracticeGroup[] @relation("GroupHierarchy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([parentId])
  @@map("practice_groups")
}

model Practice {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String?         @map("company_id") @db.Uuid
  practiceGroupId String?         @map("practice_group_id") @db.Uuid
  taxIdId         String?         @map("tax_id_id") @db.Uuid
  name            String
  npi             String?
  status          PracticeStatus
region          String
  source          PracticeSource
  bucket          String[]
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  practiceGroup   PracticeGroup?  @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  taxId           TaxId?          @relation(fields: [taxIdId], references: [id], onDelete: SetNull)
  groupNpis       GroupNpi[]      @relation("PracticeGroupNpis")
  persons         PracticePerson[]
  deals       Deal[]
  agreements  Agreement[]
  invoices    Invoice[]
  audits      Audit[]
  assessments Assessment[]

  @@index([companyId])
  @@index([practiceGroupId])
  @@index([taxIdId])
  @@map("practices")
}

model TaxId {
  id              String       @id @default(uuid()) @db.Uuid
  taxIdNumber     String       @unique @map("tax_id_number")
  legalEntityName String       @map("legal_entity_name")
  status          EntityStatus @default(ACTIVE)
  notes           String?
  companyId       String       @map("company_id") @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupNpis       GroupNpi[]
  practices       Practice[]
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("tax_ids")
}

model PracticePerson {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String @map("practice_id") @db.Uuid
  personId   String  @map("person_id") @db.Uuid
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  person     Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([personId])
  @@unique([practiceId, personId])
  @@map("practice_persons")
}

model CompanyPerson {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([personId])
  @@unique([companyId, personId])
  @@map("company_persons")
}

model GroupNpi {
  id              String         @id @default(uuid()) @db.Uuid
  groupNpiNumber  String         @unique @map("group_npi_number")
  groupName       String         @map("group_name")
  status          EntityStatus   @default(ACTIVE)
  notes           String?
  taxId           String?        @map("tax_id") @db.Uuid
  tax             TaxId?        @relation(fields: [taxId], references: [id], onDelete: Cascade)
  practiceGroupId String?        @map("practice_group_id") @db.Uuid
  practiceGroup   PracticeGroup? @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  practices       Practice[]     @relation("PracticeGroupNpis")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([taxId])
  @@index([practiceGroupId])
  @@map("group_npis")
}

model Person {
  id          String          @id @default(uuid()) @db.Uuid
  firstName   String          @map("first_name")
  lastName    String          @map("last_name")
  role        PersonRole
  designation String?
  influence   InfluenceLevel
  email       String?
  phone       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  practices   PracticePerson[]
  companies   CompanyPerson[]

  @@map("contacts")
}

model Deal {
  id                String      @id @default(uuid()) @db.Uuid
  practiceId        String      @map("practice_id") @db.Uuid
  stage             DealStage
  value             Decimal     @db.Decimal(12, 2)
  probability       Int
  expectedCloseDate DateTime?   @map("expected_close_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  practice          Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreements        Agreement[]
  audits            Audit[]

  @@index([practiceId])
  @@map("deals")
}

model Agreement {
  id                    String           @id @default(uuid()) @db.Uuid
  practiceId            String           @map("practice_id") @db.Uuid
  dealId                String?          @map("deal_id") @db.Uuid
  type                  AgreementType
  status                AgreementStatus
  effectiveDate         DateTime?        @map("effective_date")
  renewalDate           DateTime?        @map("renewal_date")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @default(now()) @updatedAt @map("updated_at")
  practice              Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal                  Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoices              Invoice[]
  channelPartners       ChannelPartner[]
  docusealSubmissions   DocusealSubmission[]

  @@index([practiceId])
  @@index([dealId])
  @@map("agreements")
}

model DocusealSubmission {
  id            String    @id @default(uuid()) @db.Uuid
  agreementId   String    @map("agreement_id") @db.Uuid
  externalId    Int       @map("external_id")
  status        String
  url           String?
  embedUrl      String?
  slug          String?
  submitterUuid String?   @map("submitter_uuid")
  templateId    Int?      @map("template_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  agreement     Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)

  @@index([agreementId])
  @@map("docuseal_submissions")
}

model Service {
  id         String            @id @default(uuid()) @db.Uuid
  name       String
  clientRate Decimal           @map("client_rate") @db.Decimal(12, 2)
  vendorRate Decimal           @map("vendor_rate") @db.Decimal(12, 2)
  margin     Decimal           @db.Decimal(5, 2)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at")
  lineItems  InvoiceLineItem[]

  @@map("services")
}

model Invoice {
  id            String            @id @default(uuid()) @db.Uuid
  practiceId    String            @map("practice_id") @db.Uuid
  agreementId   String?           @map("agreement_id") @db.Uuid
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus
  dueDate       DateTime?         @map("due_date")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")
  practice      Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreement     Agreement?        @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  purchaseOrders PurchaseOrder[]

  @@index([practiceId])
  @@index([agreementId])
  @@map("invoices")
}

model InvoiceLineItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  serviceId  String   @map("service_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([serviceId])
  @@map("invoice_line_items")
}

model PurchaseOrder {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  totalCost Decimal  @map("total_cost") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([invoiceId])
  @@map("purchase_orders")
}

model Vendor {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  type           VendorType
  renewalDate    DateTime?       @map("renewal_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model Audit {
  id              String    @id @default(uuid()) @db.Uuid
  practiceId      String    @map("practice_id") @db.Uuid
  dealId          String?   @map("deal_id") @db.Uuid
  type            AuditType
  score           Decimal?  @db.Decimal(5, 2)
  findings        Json
  recommendations Json
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([dealId])
  @@map("audits")
}

model Assessment {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  responses  Json
  score      Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@map("assessments")
}

model Onboarding {
  id                                               String           @id @default(uuid()) @db.Uuid

  // Section 1: Client Structure
  onboardingType                                   OnboardingType?  @map("onboarding_type")
  isAuthorizedPerson                              Boolean?         @map("is_authorized_person")
  nonAuthorizedRole                               String?          @map("non_authorized_role")
  numberOfPractices                               Int?             @map("number_of_practices")
  numberOfLocations                               Int?             @map("number_of_locations")
  billingManagedCentrally                         String?          @map("billing_managed_centrally")
  credentialingManagedCentrally                   String?          @map("credentialing_managed_centrally")
  contractingManagedCentrally                     String?          @map("contracting_managed_centrally")
  oneMainContact                                  Boolean?         @map("one_main_contact")

  // Section 2: Company Information
  legalCompanyName                                String?          @map("legal_company_name")
  dbaName                                         String?          @map("dba_name")
  organizationType                                OrganizationType? @map("organization_type")
  taxIdEin                                        String?          @map("tax_id_ein")
  mainCompanyPhone                                String?          @map("main_company_phone")
  mainCompanyFax                                  String?          @map("main_company_fax")
  mainCompanyEmail                                String?          @map("main_company_email")
  companyWebsite                                  String?          @map("company_website")
  companyAddressLine1                             String?          @map("company_address_line_1")
  companyAddressLine2                             String?          @map("company_address_line_2")
  companyCity                                     String?          @map("company_city")
  companyState                                    String?          @map("company_state")
  companyZip                                      String?          @map("company_zip")
  ownershipType                                   OwnershipType?  @map("ownership_type")
  statesOfOperation                               String[]         @map("states_of_operation")
  isLegalContractingEntity                       Boolean?         @map("is_legal_contracting_entity")
  isBillingEntity                                 Boolean?         @map("is_billing_entity")
  isCredentialingEntity                           Boolean?         @map("is_credentialing_entity")
  primarySpecialty                                String?          @map("primary_specialty")
  additionalSpecialties                           String[]         @map("additional_specialties")

  // Section 7: Services Requested
  requestedServices                               ServiceType[]    @map("requested_services")
  primaryServiceToLaunch                          String?          @map("primary_service_to_launch")
  requestedGoLiveDate                             DateTime?        @map("requested_go_live_date")
  priorityLevel                                   String?          @map("priority_level")
  servicesForAllPractices                        String?          @map("services_for_all_practices")
  replacingExistingVendor                        Boolean?         @map("replacing_existing_vendor")
  currentVendorName                               String?          @map("current_vendor_name")
  currentVendorEndDate                            DateTime?        @map("current_vendor_end_date")
  engagementGoals                                 String?          @map("engagement_goals")

  // Final Review / Submission
  informationAccurate                            Boolean?         @map("information_accurate")
  authorizeUse                                    Boolean?         @map("authorize_use")
  submittedByName                                 String?          @map("submitted_by_name")
  submittedByTitle                                String?          @map("submitted_by_title")
  submissionDate                                  DateTime?        @map("submission_date")

  status                                          OnboardingStatus @default(DRAFT)
  createdAt                                       DateTime         @default(now()) @map("created_at")
  updatedAt                                       DateTime         @default(now()) @updatedAt @map("updated_at")

  // Relations
  contacts                                        OnboardingContact[]
  practices                                       OnboardingPractice[]
  documents                                       OnboardingDocument[]
  billing                                         OnboardingBilling?
  credentialing                                   OnboardingCredentialing?
  technology                                      OnboardingTechnology?
  outreach                                        OnboardingOutreach?
  labPharmacy                                     OnboardingLabPharmacy?
  compliance                                      OnboardingCompliance?

  @@map("onboardings")
}

model OnboardingContact {
  id                       String     @id @default(uuid()) @db.Uuid
  onboardingId             String     @map("onboarding_id") @db.Uuid
  fullName                 String?    @map("full_name")
  jobTitle                 String?    @map("job_title")
  contactRole              String?    @map("contact_role")
  email                    String?
  phone                    String?
  extension                String?
  preferredContactMethod   String?    @map("preferred_contact_method")
  bestTimeToReach          String?    @map("best_time_to_reach")
  isPrimaryDecisionMaker  Boolean?   @map("is_primary_decision_maker")
  canSignAgreements        Boolean?   @map("can_sign_agreements")
  additionalResponsibilities String[] @map("additional_responsibilities")
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @default(now()) @updatedAt @map("updated_at")

  onboarding               Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_contacts")
}

model OnboardingPractice {
  id                                  String     @id @default(uuid()) @db.Uuid
  onboardingId                        String     @map("onboarding_id") @db.Uuid
  practiceName                        String?    @map("practice_name")
  practiceDbaName                    String?    @map("practice_dba_name")
  isPartOfParentCompany              Boolean?   @map("is_part_of_parent_company")
  practiceType                        String?    @map("practice_type")
  additionalSpecialtyAreas           String[]   @map("additional_specialty_areas")
  groupNpi                           String?    @map("group_npi")
  taxIdEin                           String?    @map("tax_id_ein")
  approximateNumberOfProviders       Int?       @map("approximate_number_of_providers")
  approximateNumberOfLocations       Int?       @map("approximate_number_of_locations")
  approximateMonthlyPatientVolume    Int?       @map("approximate_monthly_patient_volume")
  approximateMedicarePatientVolume   Int?       @map("approximate_medicare_patient_volume")
  approximateMedicaidPatientVolume   Int?       @map("approximate_medicaid_patient_volume")
  approximateCommercialPatientVolume Int?       @map("approximate_commercial_patient_volume")
  offersCareManagementServices       Boolean?   @map("offers_care_management_services")
  currentServicesOffered             String[]   @map("current_services_offered")
  operationalPainPoints              String[]   @map("operational_pain_points")
  additionalNotes                    String?    @map("additional_notes")
  createdAt                          DateTime   @default(now()) @map("created_at")
  updatedAt                          DateTime   @default(now()) @updatedAt @map("updated_at")

  onboarding                         Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  locations                          OnboardingLocation[]
  providers                          OnboardingProvider[]

  @@index([onboardingId])
  @@map("onboarding_practices")
}

model OnboardingLocation {
  id                          String   @id @default(uuid()) @db.Uuid
  onboardingPracticeId        String   @map("onboarding_practice_id") @db.Uuid
  locationName                String?  @map("location_name")
  isPrimaryLocation           Boolean? @map("is_primary_location")
  addressLine1                String?  @map("address_line_1")
  addressLine2                String?  @map("address_line_2")
  city                        String?
  state                       String?
  zipCode                     String?  @map("zip_code")
  mainPhoneNumber             String?  @map("main_phone_number")
  mainFaxNumber               String?  @map("main_fax_number")
  officeEmail                 String?  @map("office_email")
  hoursOfOperation            String?  @map("hours_of_operation")
  officeManagerName           String?  @map("office_manager_name")
  patientOutreachManaged      String?  @map("patient_outreach_managed")
  billingManaged              String?  @map("billing_managed")
  notes                       String?
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @default(now()) @updatedAt @map("updated_at")

  onboardingPractice          OnboardingPractice @relation(fields: [onboardingPracticeId], references: [id], onDelete: Cascade)

  @@index([onboardingPracticeId])
  @@map("onboarding_locations")
}

model OnboardingProvider {
  id                    String   @id @default(uuid()) @db.Uuid
  onboardingPracticeId  String   @map("onboarding_practice_id") @db.Uuid
  firstName             String?  @map("first_name")
  lastName              String?  @map("last_name")
  credentials           String?
  providerType          String?  @map("provider_type")
  specialty             String?
  npi                   String?
  caqhId                String?  @map("caqh_id")
  stateLicenseNumber    String?  @map("state_license_number")
  deaNumber             String?  @map("dea_number")
  boardCertified        Boolean? @map("board_certified")
  employmentStatus      String?  @map("employment_status")
  participatingLocations String[] @map("participating_locations")
  credentialingNeeded   String?  @map("credentialing_needed")
  recredentialingNeeded String?  @map("recredentialing_needed")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at")

  onboardingPractice    OnboardingPractice @relation(fields: [onboardingPracticeId], references: [id], onDelete: Cascade)

  @@index([onboardingPracticeId])
  @@map("onboarding_providers")
}

model OnboardingDocument {
  id                  String    @id @default(uuid()) @db.Uuid
  onboardingId        String    @map("onboarding_id") @db.Uuid
  documentType        String    @map("document_type")
  fileName            String?   @map("file_name")
  fileUrl             String?   @map("file_url")
  required            Boolean?
  status              String?
  dateRequested       DateTime? @map("date_requested")
  dateReceived        DateTime? @map("date_received")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  onboarding          Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_documents")
}

model OnboardingBilling {
  id                           String   @id @default(uuid()) @db.Uuid
  onboardingId                 String   @unique @map("onboarding_id") @db.Uuid
  currentBillingModel         String?  @map("current_billing_model")
  billingCompanyName          String?  @map("billing_company_name")
  mainBillingContactName      String?  @map("main_billing_contact_name")
  mainBillingContactEmail     String?  @map("main_billing_contact_email")
  mainBillingContactPhone     String?  @map("main_billing_contact_phone")
  currentlyBilledServices     String[] @map("currently_billed_services")
  activePayers                String?  @map("active_payers")
  eftEraSetup                 String?  @map("eft_era_setup")
  invoiceRecipient            String?  @map("invoice_recipient")
  invoiceEmail                String?  @map("invoice_email")
  preferredReportingCadence  String?  @map("preferred_reporting_cadence")
  billingPainPoints           String[] @map("billing_pain_points")
  additionalNotes             String?  @map("additional_notes")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @default(now()) @updatedAt @map("updated_at")

  onboarding                   Onboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)

  @@index([onboardingId])
  @@map("onboarding_billing")
}

