generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRoles {
 SALES
 ACCOUNTMANAGER
 OPERATIONS
 FINANCE
 VIEWER
}

enum PracticeStatus {
  LEAD
  ACTIVE
  INACTIVE
  CLOSED
}

enum PracticeSource {
  DIRECT
  REFERRAL
  CHANNEL_PARTNER
  OUTBOUND
  INBOUND
}

enum PersonRole {
  OWNER
  ADMIN
  FINANCE
  OPERATIONS
  CLINICAL
  PROCUREMENT
  OTHER
}

enum InfluenceLevel {
  LOW
  MEDIUM
  HIGH
  DECISION_MAKER
}

enum DealStage {
  PROSPECTING
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum AgreementType {
  MSA
  SOW
  RENEWAL
  ADDENDUM
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum VendorType {
  BILLING
  CODING
  RCM
  COMPLIANCE
  TECHNOLOGY
  OTHER
}

enum AuditType {
  COMPLIANCE
  CODING
  DOCUMENTATION
  REVENUE_CYCLE
  OPERATIONAL
}

enum ChannelPartnerType {
  RESELLER
  REFERRAL
  IMPLEMENTATION
  STRATEGIC
}

enum CompanyStatus {
  LEAD
  CUSTOMER
  PARTNER
  INACTIVE
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  userName  String    @unique
  firstName String
  lastName  String
  email     String    @unique
  password  String
  role      UserRoles
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  companies Company[]

  @@map("User")
}

model Company {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  domain    String?
  industry  String?
  size      Int?
  revenue   Decimal?      @db.Decimal(15, 2)
  phone     String?
  email     String?
  website   String?
  street    String?
  city      String?
  state     String?
  country   String?
  zip       String?
  status    CompanyStatus @default(LEAD)
  ownerId   String        @map("owner_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  practices Practice[]

  @@index([ownerId])
  @@map("companies")
}

model Practice {
  id          String          @id @default(uuid()) @db.Uuid
  companyId   String?         @map("company_id") @db.Uuid
  name        String
  status      PracticeStatus
  region      String
  source      PracticeSource
  bucket      String[]
  ownerId     String          @map("owner_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @default(now()) @updatedAt @map("updated_at")
  company     Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  persons     Person[]
  deals       Deal[]
  agreements  Agreement[]
  invoices    Invoice[]
  audits      Audit[]
  assessments Assessment[]

  @@index([ownerId])
  @@index([companyId])
  @@map("practices")
}

model Person {
  id         String         @id @default(uuid()) @db.Uuid
  practiceId String         @map("practice_id") @db.Uuid
  firstName  String         @map("first_name")
  lastName   String         @map("last_name")
  role       PersonRole
  influence  InfluenceLevel
  email      String?        @unique
  phone      String?
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  practice   Practice       @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@map("contacts")
}

model Deal {
  id                String      @id @default(uuid()) @db.Uuid
  practiceId        String      @map("practice_id") @db.Uuid
  stage             DealStage
  value             Decimal     @db.Decimal(12, 2)
  probability       Int
  expectedCloseDate DateTime?   @map("expected_close_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  practice          Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreements        Agreement[]
  audits            Audit[]

  @@index([practiceId])
  @@map("deals")
}

model Agreement {
  id            String           @id @default(uuid()) @db.Uuid
  practiceId    String           @map("practice_id") @db.Uuid
  dealId        String?          @map("deal_id") @db.Uuid
  type          AgreementType
  status        AgreementStatus
  effectiveDate DateTime?        @map("effective_date")
  renewalDate   DateTime?        @map("renewal_date")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at")
  practice      Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal          Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoices      Invoice[]
  channelPartners ChannelPartner[]

  @@index([practiceId])
  @@index([dealId])
  @@map("agreements")
}

model Service {
  id         String            @id @default(uuid()) @db.Uuid
  name       String
  clientRate Decimal           @map("client_rate") @db.Decimal(12, 2)
  vendorRate Decimal           @map("vendor_rate") @db.Decimal(12, 2)
  margin     Decimal           @db.Decimal(5, 2)
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at")
  lineItems  InvoiceLineItem[]

  @@map("services")
}

model Invoice {
  id            String            @id @default(uuid()) @db.Uuid
  practiceId    String            @map("practice_id") @db.Uuid
  agreementId   String?           @map("agreement_id") @db.Uuid
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus
  dueDate       DateTime?         @map("due_date")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")
  practice      Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreement     Agreement?        @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  purchaseOrders PurchaseOrder[]

  @@index([practiceId])
  @@index([agreementId])
  @@map("invoices")
}

model InvoiceLineItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  serviceId  String   @map("service_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([serviceId])
  @@map("invoice_line_items")
}

model PurchaseOrder {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  totalCost Decimal  @map("total_cost") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([invoiceId])
  @@map("purchase_orders")
}

model Vendor {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  type           VendorType
  renewalDate    DateTime?       @map("renewal_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model Audit {
  id              String    @id @default(uuid()) @db.Uuid
  practiceId      String    @map("practice_id") @db.Uuid
  dealId          String?   @map("deal_id") @db.Uuid
  type            AuditType
  score           Decimal?  @db.Decimal(5, 2)
  findings        Json
  recommendations Json
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  practice        Practice  @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([practiceId])
  @@index([dealId])
  @@map("audits")
}

model Assessment {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String   @map("practice_id") @db.Uuid
  responses  Json
  score      Decimal? @db.Decimal(5, 2)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@map("assessments")
}

model ChannelPartner {
  id          String             @id @default(uuid()) @db.Uuid
  name        String
  type        ChannelPartnerType
  agreementId String?            @map("agreement_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")
  agreement   Agreement?         @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  @@index([agreementId])
  @@map("channel_partners")
}
