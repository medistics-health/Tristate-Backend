enum BillingModel {
  IN_HOUSE
  OUTSOURCED
  HYBRID
}

enum PricingModel {
  FIXED_MONTHLY
  FIXED_ONE_TIME
  PER_UNIT
  PER_ENCOUNTER
  PER_PATIENT
  PER_PROVIDER
  PER_SITE
  PER_CPT_CODE
  PERCENT_COLLECTIONS
  PERCENT_REVENUE
  PERCENT_PROFIT
  TIERED_VOLUME
  MONTHLY_MINIMUM
  HYBRID
  MULTI_COMPONENT
  RETAINER
  SUCCESS_FEE
  CUSTOM_ATTACHMENT_DEFINED
}

enum BillingRunStatus {
  PENDING
  RUNNING
  CALCULATED
  REVIEW_REQUIRED
  APPROVED
  POSTED
  FAILED
  CLOSED
}

enum VendorPayableStatus {
  DRAFT
  CALCULATED
  APPROVED
  ON_HOLD
  RELEASED
  SENT_TO_VENDOR
  PAYABLE
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum ReleasePolicy {
  ON_INVOICE_APPROVAL
  ON_CLIENT_PAYMENT
  MANUAL
}

enum ApprovalEntityType {
  BILLING_RUN
  BILLING_RUN_ITEM
  CLIENT_INVOICE
  VENDOR_PAYABLE
  AGREEMENT_TERM
}

enum ApprovalDecisionStatus {
  PENDING
  APPROVED
  REJECTED
  OVERRIDDEN
}

enum ExceptionSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ExceptionStatus {
  OPEN
  RESOLVED
  OVERRIDDEN
}

enum ExternalSystem {
  STRIPE
  QUICKBOOKS
}

enum ExternalEntityType {
  CUSTOMER
  VENDOR
  INVOICE
  PAYMENT
  BILL
  BILL_PAYMENT
  JOURNAL_ENTRY
}

enum ExternalSyncStatus {
  PENDING
  IN_PROGRESS
  SYNCED
  FAILED
  RETRYING
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  PARTIALLY_ALLOCATED
  ALLOCATED
  REFUNDED
}

enum ChannelPartnerType {
  RESELLER
  REFERRAL
  IMPLEMENTATION
  STRATEGIC
}

enum CompanyStatus {
  LEAD
  CUSTOMER
  PARTNER
  INACTIVE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum PracticeTypes {
  PRIMARY_CARE
  FAMILY_MEDICINE
  INTERNAL_MEDICINE
  PEDIATRICS
  CARDIOLOGY
  GASTROENTEROLOGY
  ENDOCRINOLOGY
  PULMONOLOGY
  NEPHROLOGY
  NEUROLOGY
  BEHAVIORAL_HEALTH
  MULTI_SPECIALTY
  OTHER
}

enum ContactRoles {
  OWNER
  PRACTICE_MANAGER
  OFFICE_MANAGER
  BILLING_CONTACT
  CREDENTIALING_CONTACT
  CLINICAL_LEAD
  TECHNICAL_CONTACT
  COMPLIANCE_CONTACT
  MARKETING_CONTACT
  AUTHORIZED_SIGNER
  OTHER
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  userName  String    @unique
  firstName String
  lastName  String
  email     String    @unique
  password  String
  role      UserRoles
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  approvedBillingRuns BillingRun[] @relation("BillingRunApprovedBy")
  approvalDecisions ApprovalDecision[] @relation("ApprovalDecisionByUser")
  resolvedExceptions ExceptionEvent[] @relation("ExceptionResolvedByUser")

  @@map("User")
}

model Company {
  id        String        @id @default(uuid()) @db.Uuid
  name      String
  domain    String?
  industry  String?
  size      Int?
  revenue   Decimal?      @db.Decimal(15, 2)
  phone     String?
  email     String?
  website   String?
  street    String?
  city      String?
  state     String?
  country   String?
  zip       String?
  status    CompanyStatus @default(LEAD)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  practiceGroups PracticeGroup[]
  practices      Practice[]
  taxIds         TaxId[]
  persons       CompanyPerson[]

  @@map("companies")
}

model PracticeGroup {
  id        String          @id @default(uuid()) @db.Uuid
  name      String
  companyId String          @map("company_id") @db.Uuid
  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  practices Practice[]
  groupNpis GroupNpi[]

  // FHIR-style recursive nesting (Groups within Groups)
  parentId  String?         @map("parent_id") @db.Uuid
  parent    PracticeGroup?  @relation("GroupHierarchy", fields: [parentId], references: [id])
  children  PracticeGroup[] @relation("GroupHierarchy")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([parentId])
  @@map("practice_groups")
}

model Practice {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String?         @map("company_id") @db.Uuid
  practiceGroupId String?         @map("practice_group_id") @db.Uuid
  taxIdId         String?         @map("tax_id_id") @db.Uuid
  name            String
  npi             String?
  status          PracticeStatus
region          String
  source          PracticeSource
  bucket          String[]
  stripeCustomerId String?        @map("stripe_customer_id")
  quickbooksCustomerId String?    @map("quickbooks_customer_id")
  defaultCurrency String?         @default("USD") @map("default_currency")
  billToTaxIdId   String?         @map("bill_to_tax_id_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")
  company         Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)
  practiceGroup   PracticeGroup?  @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  taxId           TaxId?          @relation("PracticeTaxId", fields: [taxIdId], references: [id], onDelete: SetNull)
  billToTaxId     TaxId?          @relation("PracticeBillToTaxId", fields: [billToTaxIdId], references: [id], onDelete: SetNull)
  groupNpis       GroupNpi[]      @relation("PracticeGroupNpis")
  persons         PracticePerson[]
  deals       Deal[]
  agreements  Agreement[]
  invoices    Invoice[]
  audits      Audit[]
  assessments Assessment[]
  billingRuns BillingRun[]
  billingInputSnapshots BillingInputSnapshot[]
  billingRunItems BillingRunItem[]
  vendorPayables VendorPayable[]
  payments Payment[]

  @@index([companyId])
  @@index([practiceGroupId])
  @@index([taxIdId])
  @@index([billToTaxIdId])
  @@map("practices")
}

model TaxId {
  id              String       @id @default(uuid()) @db.Uuid
  taxIdNumber     String       @unique @map("tax_id_number")
  legalEntityName String       @map("legal_entity_name")
  status          EntityStatus @default(ACTIVE)
  notes           String?
  companyId       String       @map("company_id") @db.Uuid
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  groupNpis       GroupNpi[]
  practices       Practice[]   @relation("PracticeTaxId")
  billToPractices Practice[]   @relation("PracticeBillToTaxId")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("tax_ids")
}

model PracticePerson {
  id         String   @id @default(uuid()) @db.Uuid
  practiceId String @map("practice_id") @db.Uuid
  personId   String  @map("person_id") @db.Uuid
  practice   Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  person     Person  @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([practiceId])
  @@index([personId])
  @@unique([practiceId, personId])
  @@map("practice_persons")
}

model CompanyPerson {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  personId  String   @map("person_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([personId])
  @@unique([companyId, personId])
  @@map("company_persons")
}

model GroupNpi {
  id              String         @id @default(uuid()) @db.Uuid
  groupNpiNumber  String         @unique @map("group_npi_number")
  groupName       String         @map("group_name")
  status          EntityStatus   @default(ACTIVE)
  notes           String?
  taxId           String?        @map("tax_id") @db.Uuid
  tax             TaxId?        @relation(fields: [taxId], references: [id], onDelete: Cascade)
  practiceGroupId String?        @map("practice_group_id") @db.Uuid
  practiceGroup   PracticeGroup? @relation(fields: [practiceGroupId], references: [id], onDelete: SetNull)
  practices       Practice[]     @relation("PracticeGroupNpis")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([taxId])
  @@index([practiceGroupId])
  @@map("group_npis")
}

model Person {
  id          String          @id @default(uuid()) @db.Uuid
  firstName   String          @map("first_name")
  lastName    String          @map("last_name")
  role        PersonRole
  designation String?
  influence   InfluenceLevel
  email       String?
  phone       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  practices   PracticePerson[]
  companies   CompanyPerson[]
  docusealSubmissions DocusealSubmission[]

  @@map("contacts")
}

model Deal {
  id                String      @id @default(uuid()) @db.Uuid
  practiceId        String      @map("practice_id") @db.Uuid
  stage             DealStage
  value             Decimal     @db.Decimal(12, 2)
  probability       Int
  expectedCloseDate DateTime?   @map("expected_close_date")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  practice          Practice    @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreements        Agreement[]
  audits            Audit[]

  @@index([practiceId])
  @@map("deals")
}

model Agreement {
  id                    String           @id @default(uuid()) @db.Uuid
  practiceId            String           @map("practice_id") @db.Uuid
  dealId                String?          @map("deal_id") @db.Uuid
  type                  AgreementType
  status                AgreementStatus
  effectiveDate         DateTime?        @map("effective_date")
  renewalDate           DateTime?        @map("renewal_date")
  externalReference     String?          @map("external_reference")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @default(now()) @updatedAt @map("updated_at")
  practice              Practice         @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  deal                  Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoices              Invoice[]
  channelPartners       ChannelPartner[]
  docusealSubmissions   DocusealSubmission[]
  versions              AgreementVersion[]
  serviceTerms          AgreementServiceTerm[]

  @@index([practiceId])
  @@index([dealId])
  @@map("agreements")
}

model DocusealSubmission {
  id            String    @id @default(uuid()) @db.Uuid
  agreementId   String    @map("agreement_id") @db.Uuid
  docusealSubmissionId      Int?      @unique @map("docuseal_submission_id")
  personId      String?   @map("person_id") @db.Uuid
  url           String?
  docSlug       String?
  signedDocUrl  String?   @map("signed_doc_url")
  auditLogUrl   String?   @map("audit_log_url")
  status        String?
  templateId    Int?      @map("template_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  signers      DocuSigner[]
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  person      Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([agreementId])
  @@index([personId])
  @@map("docuseal_submissions")
}

model DocuSigner {
  id           String            @id @default(uuid()) @db.Uuid
  externalId    Int?              @map("external_id")
  signerUuid   String            @map("signer_uuid")
  role        String
  name        String
  email       String
  status      String
  submissionSlug   String?
  signedUrl   String?           @map("signed_url")
  auditUrl    String?           @map("audit_url")
  signedAt    DateTime?         @map("signed_at")
  ipAddress   String?           @map("ip_address")
  order      Int

  submissionId String           @map("submission_id") @db.Uuid
  submission  DocusealSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@index([signerUuid])
  @@map("docu_signers")
}

model Service {
  id         String            @id @default(uuid()) @db.Uuid
  name       String
  code       String?
  category   String?
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at")
  lineItems  InvoiceLineItem[]
  agreementTerms AgreementServiceTerm[]
  billingInputSnapshots BillingInputSnapshot[]
  billingRunItems BillingRunItem[]
  vendorPayableLineItems VendorPayableLineItem[]

  @@map("services")
}

model Invoice {
  id            String            @id @default(uuid()) @db.Uuid
  practiceId    String            @map("practice_id") @db.Uuid
  agreementId   String?           @map("agreement_id") @db.Uuid
  totalAmount   Decimal           @map("total_amount") @db.Decimal(12, 2)
  status        InvoiceStatus
  dueDate       DateTime?         @map("due_date")
  invoiceNumber String?           @unique @map("invoice_number")
  currency      String?           @default("USD")
  billingPeriodStart DateTime?    @map("billing_period_start")
  billingPeriodEnd DateTime?      @map("billing_period_end")
  subtotalAmount Decimal?         @map("subtotal_amount") @db.Decimal(12, 2)
  taxAmount     Decimal?          @map("tax_amount") @db.Decimal(12, 2)
  discountAmount Decimal?         @map("discount_amount") @db.Decimal(12, 2)
  stripeInvoiceId String?         @map("stripe_invoice_id")
  stripeHostedInvoiceUrl String?  @map("stripe_hosted_invoice_url")
  stripeInvoicePdfUrl String?     @map("stripe_invoice_pdf_url")
  quickbooksInvoiceId String?     @map("quickbooks_invoice_id")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at")
  practice      Practice          @relation(fields: [practiceId], references: [id], onDelete: Cascade)
  agreement     Agreement?        @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  lineItems     InvoiceLineItem[]
  purchaseOrders PurchaseOrder[]
  paymentAllocations PaymentAllocation[]
  vendorPayables VendorPayable[]
  stripeEventLogs StripeEventLog[]

  @@index([practiceId])
  @@index([agreementId])
  @@map("invoices")
}

model InvoiceLineItem {
  id         String   @id @default(uuid()) @db.Uuid
  invoiceId  String   @map("invoice_id") @db.Uuid
  serviceId  String   @map("service_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(12, 2)
  description String?
  billingRunItemId String? @map("billing_run_item_id") @db.Uuid
  billingRunItemComponentId String? @map("billing_run_item_component_id") @db.Uuid
  agreementServiceTermId String? @map("agreement_service_term_id") @db.Uuid
  billingPeriodStart DateTime? @map("billing_period_start")
  billingPeriodEnd DateTime? @map("billing_period_end")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  billingRunItem BillingRunItem? @relation(fields: [billingRunItemId], references: [id], onDelete: SetNull)
  billingRunItemComponent BillingRunItemComponent? @relation(fields: [billingRunItemComponentId], references: [id], onDelete: SetNull)
  agreementServiceTerm AgreementServiceTerm? @relation(fields: [agreementServiceTermId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([serviceId])
  @@index([billingRunItemId])
  @@index([billingRunItemComponentId])
  @@index([agreementServiceTermId])
  @@map("invoice_line_items")
}

model PurchaseOrder {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  totalCost Decimal  @map("total_cost") @db.Decimal(12, 2)
  vendorPayableId String? @map("vendor_payable_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  vendor    Vendor   @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  vendorPayable VendorPayable? @relation(fields: [vendorPayableId], references: [id], onDelete: SetNull)

  @@index([vendorId])
  @@index([invoiceId])
  @@index([vendorPayableId])
  @@map("purchase_orders")
}

model Vendor {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  type           VendorType
  renewalDate    DateTime?       @map("renewal_date")
  quickbooksVendorId String?     @map("quickbooks_vendor_id")
  remitEmail     String?         @map("remit_email")
  paymentTerms   String?         @map("payment_terms")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @default(now()) @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]
  agreementTerms AgreementServiceTerm[]
  billingRunItems BillingRunItem[]
  vendorPayables VendorPayable[]

  @@map("vendors")
}

model AgreementVersion {
  id          String    @id @default(uuid()) @db.Uuid
  agreementId String    @map("agreement_id") @db.Uuid
  versionNumber Int     @map("version_number")
  isCurrent   Boolean   @default(true) @map("is_current")
  effectiveDate DateTime? @map("effective_date")
  endDate     DateTime? @map("end_date")
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")
  agreement   Agreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  serviceTerms AgreementServiceTerm[]

  @@unique([agreementId, versionNumber])
  @@index([agreementId])
  @@map("agreement_versions")
}

model AgreementServiceTerm {
  id                  String       @id @default(uuid()) @db.Uuid
  agreementId         String       @map("agreement_id") @db.Uuid
  agreementVersionId  String?      @map("agreement_version_id") @db.Uuid
  serviceId           String       @map("service_id") @db.Uuid
  vendorId            String?      @map("vendor_id") @db.Uuid
  pricingModel        PricingModel @map("pricing_model")
  pricingConfig       Json         @map("pricing_config")
  currency            String?      @default("USD")
  priority            Int          @default(1)
  minimumFee          Decimal?     @map("minimum_fee") @db.Decimal(12, 2)
  effectiveDate       DateTime?    @map("effective_date")
  endDate             DateTime?    @map("end_date")
  isActive            Boolean      @default(true) @map("is_active")
  externalReference   String?      @map("external_reference")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @default(now()) @updatedAt @map("updated_at")
  agreement           Agreement    @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  agreementVersion    AgreementVersion? @relation(fields: [agreementVersionId], references: [id], onDelete: SetNull)
  service             Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  vendor              Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  billingRunItems     BillingRunItem[]
  invoiceLineItems    InvoiceLineItem[]

  @@index([agreementId])
  @@index([agreementVersionId])
  @@index([serviceId])
  @@index([vendorId])
  @@index([effectiveDate, endDate])
  @@map("agreement_service_terms")
}

model BillingRun {
  id                String           @id @default(uuid()) @db.Uuid
  practiceId        String           @map("practice_id") @db.Uuid
  periodStart       DateTime         @map("period_start")
  periodEnd         DateTime         @map("period_end")
  status            BillingRunStatus @default(PENDING)
  approvedByUserId  String?          @map("approved_by_user_id") @db.Uuid
  approvedAt        DateTime?        @map("approved_at")
  notes             String?
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at")
